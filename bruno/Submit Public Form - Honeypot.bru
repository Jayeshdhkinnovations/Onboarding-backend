meta {
  name: Submit Public Form - Honeypot
  type: http
  seq: 24
}

post {
  url: {{base_url}}/api/public/{{published_slug}}/submit
  body: multipartForm
  auth: none
}

body:multipart-form {
  data: {"EmailField": "bot@example.com"}
  _hp: bot-detected-value
}

assert {
  res.status: eq 200
  res.body.success: eq true
}
